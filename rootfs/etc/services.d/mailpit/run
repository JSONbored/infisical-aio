#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

source /usr/local/bin/env-helpers.sh

MAILPIT_DIR="/config/aio/mailpit"
MAILPIT_UI_AUTH_FILE="${MAILPIT_DIR}/ui-auth.txt"

load_generated_env
configure_bundled_mailpit_env

if ! bundled_mailpit_enabled; then
	if smtp_is_external_configured; then
		echo "[infisical-aio] External SMTP configured. Bundled Mailpit service staying idle."
	else
		echo "[infisical-aio] Bundled Mailpit disabled. SMTP will remain unset unless you provide external SMTP settings."
	fi
	exec sleep infinity
fi

mkdir -p "${MAILPIT_DIR}" /data/mailpit
chown -R mailpit:mailpit "${MAILPIT_DIR}" /data/mailpit
chmod 700 "${MAILPIT_DIR}" /data/mailpit

if [[ ! -f ${MAILPIT_UI_AUTH_FILE} ]]; then
	echo "[infisical-aio] Missing Mailpit UI auth file at ${MAILPIT_UI_AUTH_FILE}." >&2
	exit 1
fi

exec /command/s6-setuidgid mailpit mailpit \
	--database /data/mailpit/mailpit.db \
	--disable-wal \
	--disable-version-check \
	--block-remote-css-and-fonts \
	--smtp-disable-rdns \
	--max 200 \
	--max-age 7d \
	--smtp 127.0.0.1:1025 \
	--listen 0.0.0.0:8025 \
	--ui-auth-file "${MAILPIT_UI_AUTH_FILE}"
