#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

source /usr/local/bin/env-helpers.sh

load_generated_env

wait_for_postgres() {
    local deadline=$((SECONDS + 300))
    until pg_isready -d "${DB_CONNECTION_URI}" >/dev/null 2>&1; do
        if (( SECONDS >= deadline )); then
            echo "Timed out waiting for PostgreSQL." >&2
            exit 1
        fi
        echo "Waiting for PostgreSQL to accept connections..."
        sleep 2
    done
}

wait_for_redis() {
    local deadline=$((SECONDS + 300))
    until redis-cli -u "${REDIS_URL}" ping >/dev/null 2>&1; do
        if (( SECONDS >= deadline )); then
            echo "Timed out waiting for Redis." >&2
            exit 1
        fi
        echo "Waiting for Redis to accept connections..."
        sleep 2
    done
}

wait_for_postgres
wait_for_redis

/usr/local/bin/bootstrap-infisical.sh &

exec s6-setuidgid non-root-user /bin/bash -lc 'cd /backend && exec ./standalone-entrypoint.sh'
